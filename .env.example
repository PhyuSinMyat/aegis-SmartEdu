# Local testing defaults
SECRET_KEY=dev-secret-change-me
USE_MOCK_LLM=1
DEBUG_LLM=1

# Use real Bedrock only when each tester has their own valid AWS credentials.
# Set USE_MOCK_LLM=0 after filling these in.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_BEDROCK_MODEL_ID=

# Optional Bedrock tuning
BEDROCK_MAX_TOKENS=12000
BEDROCK_RETRY_MAX_TOKENS=18000
BEDROCK_TEXT_TEMPERATURE=0
BEDROCK_CONNECT_TIMEOUT=20
BEDROCK_READ_TIMEOUT=120
BEDROCK_MAX_ATTEMPTS=3
BEDROCK_API_RETRIES=2
